{
    "name": "nai-factory",
    "version": "1.0.0",
    "scripts": {
        "dev:server": "bun --filter @nai-factory/server dev",
        "dev:web": "wait-on tcp:localhost:3000 && bun --filter @nai-factory/web dev",
        "dev": "concurrently -n \"API,WEB\" -c \"cyan,magenta\" \"bun dev:server\" \"bun dev:web\"",
        "build:server": "bun --filter @nai-factory/server build",
        "build:web": "bun --filter @nai-factory/web build",
        "build": "bun run build:server && bun run build:web"
    },
    "workspaces": [
        "web",
        "server",
        "types"
    ],
    "devDependencies": {
        "concurrently": "^9.2.1",
        "wait-on": "^9.0.10"
    }
}
