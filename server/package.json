{
    "name": "@nai-factory/server",
    "version": "1.1.1",
    "module": "src/index.js",
    "types": "src/index.ts",
    "imports": {
        "#/services": "./src/services/index.ts",
        "#/*": "./src/*"
    },
    "scripts": {
        "dev": "bun run --hot src/index.ts",
        "build": "bun run build:tag-index && bun build src/index.ts --outdir=dist --target=bun --minify --sourcemap",
        "build:prod": "rm -rf dist && bun run build:tag-index && bun build src/index.ts --outdir=dist --target=bun --minify --sourcemap=none",
        "build:tag-index": "bun run scripts/build-tag-search-index.ts",
        "start": "bun dist/index.js",
        "test": "bun test",
        "db:generate": "drizzle-kit generate",
        "db:migrate": "bun run src/db/migrate.ts",
        "check": "biome check .",
        "check:fix": "biome check --write .",
        "format": "biome format .",
        "format:fix": "biome format --write .",
        "lint": "biome lint .",
        "lint:fix": "biome lint --write ."
    },
    "dependencies": {
        "@hono/zod-validator": "^0.8.0",
        "@nai-factory/shared": "workspace:*",
        "drizzle-orm": "^0.45.2",
        "fflate": "^0.8.3",
        "flexsearch": "^0.8.212",
        "fractional-indexing-jittered": "^1.0.0",
        "handlebars": "^4.7.9",
        "hono": "^4.12.21",
        "ky": "^2.0.2",
        "pino": "^10.3.1",
        "sharp": "^0.34.5",
        "zod": "^4.4.3"
    },
    "devDependencies": {
        "@biomejs/biome": "^2.4.15",
        "@tsconfig/bun": "^1.0.10",
        "@types/bun": "^1.3.14",
        "@types/flexsearch": "^0.7.42",
        "@types/node": "^25.9.1",
        "drizzle-kit": "^0.31.10",
        "pino-pretty": "^13.1.3"
    }
}
