{
    "$schema": "https://biomejs.dev/schemas/2.4.15/schema.json",
    "extends": "//",
    "files": {
        "includes": [
            "package.json",
            "biome.json",
            "drizzle.config.ts",
            "scripts/**/*",
            "src/**/*",
            "test/**/*",
            "!src/db/migrations/**/*"
        ]
    },
    "overrides": [
        {
            "includes": ["test/**/*"],
            "linter": {
                "rules": {
                    "style": {
                        "noNonNullAssertion": "off"
                    }
                }
            }
        }
    ]
}
