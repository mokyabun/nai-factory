{
    "$schema": "https://biomejs.dev/schemas/2.4.5/schema.json",
    "extends": "//",
    "files": {
        "includes": [
            "src/**/*",
            "svelte.config.js",
            "vite.config.ts",
            "biome.json",
            "!src/lib/components/ui/**/*"
        ]
    },
    "css": {
        "parser": {
            "tailwindDirectives": true
        }
    },
    "overrides": [
        {
            "includes": ["**/*.svelte"],
            "linter": {
                "rules": {
                    "style": {
                        "useConst": "off",
                        "useImportType": "off"
                    },
                    "correctness": {
                        "noUnusedVariables": "off",
                        "noUnusedImports": "off"
                    }
                }
            },
            "html": {
                "experimentalFullSupportEnabled": true
            }
        }
    ]
}
