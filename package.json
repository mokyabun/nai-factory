{
    "name": "nai-factory",
    "version": "1.0.0",
    "private": true,
    "scripts": {
        "dev": "concurrently -n \"API,WEB\" -c \"cyan,magenta\" \"bun run dev:server\" \"bun run dev:web\"",
        "dev:server": "bun --filter '@nai-factory/server' dev",
        "dev:web": "wait-on tcp:localhost:3000 && bun --filter '@nai-factory/web' dev",
        "build": "concurrently -n \"API,WEB\" -c \"cyan,magenta\" \"bun run build:server\" \"bun run build:web\"",
        "build:server": "bun --filter '@nai-factory/server' build",
        "build:web": "bun --filter '@nai-factory/web' build",
        "db:generate": "bun --filter '@nai-factory/server' db:generate",
        "db:migrate": "bun --filter '@nai-factory/server' db:migrate",
        "check": "bun --filter @nai-factory/* check .",
        "check:fix": "bun --filter @nai-factory/* check:fix",
        "format": "bun --filter @nai-factory/* format .",
        "format:fix": "bun --filter @nai-factory/* format:fix",
        "lint": "bun --filter @nai-factory/* lint .",
        "lint:fix": "bun --filter @nai-factory/* lint:fix"
    },
    "workspaces": [
        "web",
        "server",
        "shared"
    ],
    "devDependencies": {
        "@biomejs/biome": "^2.4.15",
        "concurrently": "^9.2.1",
        "wait-on": "^9.0.10"
    }
}
